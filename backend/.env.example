# QuickLender — Environment Configuration
# Copy this file to .env and update the values

# ─── Django ───────────────────────────────────────────
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production-abc123xyz789
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─── Database ─────────────────────────────────────────
# Option A: SQLite (easiest for local dev — no setup needed)
USE_SQLITE=True

# Option B: PostgreSQL (for production or if you prefer postgres)
# USE_SQLITE=False
DB_NAME=quicklender_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# ─── Redis / Celery (optional for dev — background tasks won't run without it)
REDIS_URL=redis://localhost:6379/0

# ─── M-Pesa Daraja (Sandbox — get from developer.safaricom.co.ke)
MPESA_CONSUMER_KEY=IMbuXIjXMMApmwTuFCXiUYxTzDjl8paZwXkwN0sgIHClg6w3
MPESA_CONSUMER_SECRET=BP13JjIfGNSAe47KyxYcEAt2eIWsA49XIrECCbM9by6tgnvzS9WaDEbOyBo8aHDy
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://yourdomain.co.ke/api/v1/payments/mpesa/callback/
MPESA_ENV=sandbox

# ─── Africa's Talking SMS (Sandbox)
AT_API_KEY=your_at_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=QuickLndr

# ─── Email (console backend for dev — prints to terminal)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=QuickLender <noreply@quicklender.co.ke>

# ─── Security (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# ─── AWS S3 (optional — only needed if storing documents in S3)
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_STORAGE_BUCKET_NAME=quicklender-docs
